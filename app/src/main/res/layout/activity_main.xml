<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/soccerpp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/soccerTeams"
        android:layout_width="263dp"
        android:layout_height="167dp"
        android:layout_marginStart="96dp"
        android:layout_marginTop="94dp"
        android:layout_marginEnd="53dp"
        android:layout_marginBottom="55dp"
        android:fontFamily="monospace"
        android:text="TOP SOCCER TEAMS"
        android:textColor="#F44336"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/teamsDisplayId"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/teamsDisplayId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="169dp"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="170dp"
        android:layout_marginBottom="383dp"
        android:fontFamily="monospace"
        android:text="TEAMS"
        android:textColor="#D3E61F"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/soccerTeams" />
</androidx.constraintlayout.widget.ConstraintLayout>